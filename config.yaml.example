# ArrakisEngine Configuration
# Copy this file to config.yaml and fill in your details:
#   cp config.yaml.example config.yaml

players:
  - username: your_chess_com_username       # Chess.com username (required, used by harvester)
    slug: yourfriendlyslug                  # v1.16.1: URL slug (optional — auto-derived from display_name)
    lichess_username: your_lichess_username  # Lichess username (optional)
    fide_id: null                           # FIDE player ID (optional, e.g., 1234567)
    display_name: Player 1
    age: null
    rating: null
  - username: another_chess_com_username
    # slug omitted → auto-derived from display_name ("Player 2" → "player2")
    display_name: Player 2
    age: null
    rating: null

# v1.16.1 note: `slug` is the human-facing identifier used in URLs
# (`http://localhost:3000/<slug>/patterns`), API params
# (`?player=<slug>`), and the CLI (`--player <slug>`). It's
# auto-derived from `display_name` if omitted — "Evan Leong" becomes
# "evanleong". Specify explicitly only when you want a custom slug
# different from the auto-derived form. Chess.com renames only touch
# `username`, never the slug, so bookmarks stay permanent.

stockfish:
  # Stockfish binary path — adjust for your system:
  #   macOS (Homebrew ARM): /opt/homebrew/bin/stockfish
  #   macOS (Homebrew Intel): /usr/local/bin/stockfish
  #   Linux: /usr/bin/stockfish
  #   Any OS (if on PATH): stockfish
  path: stockfish
  depth: 22
  threads: 6
  hash_mb: 512
  move_time_limit: 10.0  # max seconds per move (prevents hangs on complex positions)

analysis:
  months_lookback: 6
  time_classes:
    - rapid
    - blitz
    - bullet
    - daily

coaching:
  default_provider: claude                # claude | openai | gemini | grok | mistral | deepseek | qwen | ollama

  # Cloud providers — set API keys in .env.
  # v1.7.0 standardized on the newer reasoning models below. Older models
  # (gpt-5.4, claude-opus-4-6) are not reliable at following structured
  # output formats like the v1.13.0 phase-by-phase player feedback —
  # always prefer the values below for best coaching output quality.
  anthropic_model: claude-opus-4-7              # Anthropic Claude (ARRAKIS_ANTHROPIC_API_KEY)
  openai_model: gpt-5.5-pro-2026-04-23          # OpenAI ChatGPT (ARRAKIS_OPENAI_API_KEY)
  gemini_model: gemini-2.5-pro                  # Google Gemini (ARRAKIS_GOOGLE_API_KEY)
  grok_model: grok-3                      # xAI Grok (ARRAKIS_XAI_API_KEY)
  mistral_model: mistral-medium-latest    # Mistral AI (ARRAKIS_MISTRAL_API_KEY)
  deepseek_model: deepseek-reasoner       # DeepSeek Cloud (ARRAKIS_DEEPSEEK_API_KEY)
  qwen_model: qwen3-235b-a22b            # Alibaba Qwen (ARRAKIS_QWEN_API_KEY)

  # Local provider — no API key needed, requires `ollama serve` running
  ollama_model: deepseek-r1:8b            # Ollama local model
  ollama_base_url: http://localhost:11434  # Ollama server URL

  tone: balanced                     # encouraging | balanced | technical
  detail_level: standard             # concise | standard | detailed
  focus_areas:                       # areas to emphasize in coaching feedback
    - openings
    - tactics
    - endgames
    - time_management
    - positional_play
  custom_instructions: ""            # free-form instructions injected into coaching prompt

  # How many recent coached games to inject into the LLM prompt as "coaching history",
  # so the model avoids repeating prior advice and builds on past lessons.
  # Default: 5. Range: 1-20. Each game adds ~500 prompt tokens.
  #   5  = ~2,500 tokens added (safe for all 8 providers, including Ollama 8B local)
  #   10 = ~5,000 tokens added (safe for cloud providers; tight on Ollama 8B)
  #   15 = ~7,500 tokens added (cloud providers only)
  #   20 = ~10,000 tokens added (large-context cloud providers only — Claude, Gemini)
  # Note: trajectory injection (v1.8.0, see below) adds ~250 more tokens on top.
  coaching_history_count: 5

  # v1.8.0+ — per-player trajectory injection. When true, the per-game coaching
  # prompt also includes a structured "Player Trajectory (last 30 days)" block
  # derived from player_patterns.stats_json. The block lists 6-8 measured
  # cross-game signals (weakest phase, ACPL trend, tactical miss rate, endgame
  # conversion, comeback/collapse rates, repertoire focus) so the LLM can
  # ground its feedback in the broader arc rather than treating each game as
  # standalone. Adds ~250 prompt tokens.
  #
  # Recommended ON for cloud providers (Claude, Gemini, GPT). Consider OFF
  # for Ollama 8B local if you're already running high coaching_history_count.
  # The CLI flag `python main.py coach --no-trajectory` overrides per-run.
  coaching_trajectory_enabled: true

schedule:
  enabled: false                       # set to true to auto-run the pipeline on a timer
  interval_hours: 6                    # how often (in hours) to run the pipeline
  run_on_startup: false                # if true, run immediately when the server starts

features:
  # Hunter Mode (v1.4.1+) — opponent prep view at /[player]/hunt/[opponent].
  # When enabled, the dashboard exposes /api/hunt/* endpoints that fetch
  # an opponent's recent public games from chess.com or lichess and
  # compute their opening profile. Cached for 24 hours per opponent.
  # Set to false if you want to disable opponent prep entirely.
  hunter_mode: true

  # Sliding window for opponent game history (v1.4.4+). Games older than
  # `hunter_lookback_months` are pruned on each fetch, so the profile
  # always reflects "the last N months of play" — no stale data.
  hunter_lookback_months: 6

  # Optional hard cap on accumulated games per opponent (v1.4.4+).
  # If set, the oldest games above the cap are pruned even if they fall
  # within the lookback window. Leave null for no cap.
  # Disk cost is ~3 KB per stored game (raw PGN).
  hunter_max_games_per_opponent: null

  # Deep Scan (v1.20.0) — how many of an opponent's most-recent games the
  # opt-in "Tactical Blind Spots" scan analyzes with Stockfish (depth from
  # the `stockfish:` block above). Higher = more complete tactical picture
  # but a longer scan (depth-22 is minutes per game). Incremental: a
  # re-scan only analyzes newly-fetched games.
  hunter_scan_games: 20

  # Tournament Prep (v1.21.0) — a saved, named roster of opponents with a
  # combined cross-opponent analysis (which openings to play / avoid, plus
  # field-wide tactical blind spots).
  #   tournament_max_opponents — hard cap on roster size per event.
  #   tournament_min_shared    — only surface an opening in the combined
  #     view when at least this many opponents share it (keeps
  #     single-opponent noise out of the headline).
  tournament_max_opponents: 32
  tournament_min_shared: 2

database:
  path: data/chess_coach.db
